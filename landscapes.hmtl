    </main>

    <footer id="contatti">
        <div class="footer-container">
            <h3>Contatti</h3>
            <a href="mailto:info@studiofilipponi.com" class="email-link">info@studiofilipponi.com</a>
            <div class="copyright">
                <p>&copy; 2026 Pixeldreams. Tutti i diritti riservati.</p>
            </div>
        </div>
    </footer>

    <script>
      // Mantiene la protezione del tasto destro anche per questa pagina dedicata
      window.addEventListener('contextmenu', function (e) {
        if (e.target.tagName === 'IMG' || e.target.closest('.internal-gallery-item')) {
          e.preventDefault();
        }
      }, true);
    </script>
</body>
</html>
